    sh:targetClass <https://w3id.org/geosrs/cs/TemporalMeasureCoordinateSystem> .

geosrs:1DCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:maxCount 1 ;
    sh:message "A 1D coordinate system should have exactly one axis"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:3DCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:message "A 3D coordinate system should have at least three axes"@en ;
    sh:minCount 3 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:CRS_coordinateSystem_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//CoordinateSystem> ;
    sh:maxCount 1 ;
    sh:message "A coordinate reference system should have exactly one coordinate system"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//coordinateSystem> .

geosrs:CRS_datumEnsemble_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//DatumEnsemble> ;
    sh:maxCount 1 ;
    sh:message "A coordinate reference system may have exactly one datum ensemble"@en ;
    sh:path <https://w3id.org/geosrs//datumEnsemble> .

geosrs:CRS_datum_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//Datum> ;
    sh:maxCount 1 ;
    sh:message "A coordinate reference system should have exactly one datum"@en ;
    sh:path <https://w3id.org/geosrs//datum> .

geosrs:CRS_domainOfValidity_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//AreaOfUse> ;
    sh:message "A coordinate reference system should have at least one area of use"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//domainOfValidity> .

geosrs:CompoundCRS_includesSRS_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//SingleCRS> ;
    sh:message "A compound coordinate reference system should consist of at least one single coordinate reference system"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//includesSRS> .

geosrs:ConicalCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:message "A conical coordinate system should have at least three axes"@en ;
    sh:minCount 3 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:CoordinateSystemAxis_axisDirection_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/AxisDirection> ;
    sh:maxCount 1 ;
    sh:message "A coordinate system axis should have exactly one axis direction"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/cs/axisDirection> .

geosrs:CoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:message "A coordinate system should have at least one axis"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:CurvilinearCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:message "A curvilinear coordinate system is defined in Euclidean space and should therefore have at least three axes"@en ;
    sh:minCount 3 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:CylindricalCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:message "A cylindrical coordinate system should have at least three axes"@en ;
    sh:minCount 3 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:DateTimeTemporalCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:maxCount 1 ;
    sh:message "A date time temporal coordinate system should have exactly one axis"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:Datum_ellipsoid_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/datum/Ellipsoid> ;
    sh:maxCount 1 ;
    sh:message "A datum should have exactly one Ellipsoid definition"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/datum/ellipsoid> .

geosrs:Datum_primeMeridian_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/datum/PrimeMeridian> ;
    sh:maxCount 1 ;
    sh:message "A datum should have at most one PrimeMeridian definition"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/datum/primeMeridian> .

geosrs:Ellipsoid_eccentricity_Shape_Property a sh:PropertyShape ;
    sh:class xsd:double ;
    sh:maxCount 1 ;
    sh:message "An ellipsoid should have only one eccentricity description"@en ;
    sh:path <https://w3id.org/geosrs/datum/eccentricity> .

geosrs:Ellipsoid_inverseFlattening_Shape_Property a sh:PropertyShape ;
    sh:class xsd:double ;
    sh:maxCount 1 ;
    sh:message "An ellipsoid should have only one inverseFlattening description"@en ;
    sh:path <https://w3id.org/geosrs/datum/inverseFlattening> .

geosrs:Ellipsoid_semiMajorAxis_Shape_Property a sh:PropertyShape ;
    sh:class xsd:double ;
    sh:maxCount 1 ;
    sh:message "An ellipsoid should have only one semiMajorAxis description"@en ;
    sh:path <https://w3id.org/geosrs/datum/semiMajorAxis> .

geosrs:Ellipsoid_semiMinorAxis_Shape_Property a sh:PropertyShape ;
    sh:class xsd:double ;
    sh:maxCount 1 ;
    sh:message "An ellipsoid should have only one semiMinorAxis description"@en ;
    sh:path <https://w3id.org/geosrs/datum/semiMinorAxis> .

geosrs:GeodeticCRS_coordinateSystem_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//GeodeticCoordinateSystem> ;
    sh:maxCount 1 ;
    sh:message "A geodetic coordinate reference system should have exactly one geodetic coordinate system"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//coordinateSystem> .

geosrs:GeographicCRS_coordinateSystem_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//EllipsoidalCoordinateSystem> ;
    sh:maxCount 1 ;
    sh:message "A geographic coordinate reference system should have exactly one ellipsoidal coordinate system"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//coordinateSystem> .

geosrs:GeographicCRS_datum_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//GeodeticDatum> ;
    sh:maxCount 1 ;
    sh:message "A geographic coordinate reference system should have exactly one geodetic datum"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//datum> .

geosrs:ParametricCRS_datum_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//ParametricDatum> ;
    sh:maxCount 1 ;
    sh:message "A parametric coordinate reference system should have exactly one parametric datum"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//datum> .

geosrs:ParametricDatum_definingParameter_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/datum/DefiningParameter> ;
    sh:message "A parametric datum should have at least one defining parameter"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/datum/definingParameter> .

geosrs:PlanarCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:message "A planar coordinate system should have at least two axes"@en ;
    sh:minCount 2 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:ProjectedCRS_conversion_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//Conversion> ;
    sh:message "A projected coordinate reference system should have at least one conversion"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//conversion> .

geosrs:SingleCRS_coordinateSystem_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//CoordinateSystem> ;
    sh:maxCount 1 ;
    sh:message "A single coordinate reference system should have exactly one coordinate system"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//coordinateSystem> .

geosrs:SingleCRS_datum_Shape_Property a sh:PropertyShape ;
