    sh:path <https://w3id.org/geosrs//datum> .

geosrs:TemporalCRS_datum_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs//TemporalDatum> ;
    sh:maxCount 1 ;
    sh:message "A projected coordinate reference system should have exactly one temporal datum"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs//datum> .

geosrs:TemporalCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:maxCount 1 ;
    sh:message "A temporal coordinate system should have exactly one axis"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:TemporalCountCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:maxCount 1 ;
    sh:message "A temporal count coordinate system should have exactly one axis"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

geosrs:TemporalMeasureCoordinateSystem_axis_Shape_Property a sh:PropertyShape ;
    sh:class <https://w3id.org/geosrs/cs/CoordinateSystemAxis> ;
    sh:maxCount 1 ;
    sh:message "A temporal measure coordinate system should have exactly one axis"@en ;
    sh:minCount 1 ;
    sh:path <https://w3id.org/geosrs/cs/axis> .

